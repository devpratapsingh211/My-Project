<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thakur Puran Singh Ratya</title>
    <meta name="description" content="Public complaint portal for Thakur Puran Singh Ratya, Adhyaksh of Kisan Mazdur Sangathan." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ComplaintPortal.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="site-shell site-nav">
            <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index">Kisan Mazdur Sangathan</a>
            <a class="top-link" href="#complaint-form">Complaint Form</a>
        </div>
    </header>
    <div class="site-shell">
        <main role="main" class="site-main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="site-shell">
            <p>&copy; 2026 Complaint Portal for Thakur Puran Singh Ratya</p>
            <p>Mail delivery target: devpratapsingh211@gmail.com</p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
