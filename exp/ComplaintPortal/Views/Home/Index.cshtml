@model ComplaintPortal.Models.ComplaintFormModel
@{
    ViewData["Title"] = "Complaint Portal";
    var statusMessage = TempData["StatusMessage"] as string;
    var statusType = TempData["StatusType"] as string ?? "success";
}

<section class="hero-section">
    <div class="hero-copy">
        <p class="eyebrow">Public Complaint Portal</p>
        <h1>Thakur Puran Singh Ratya</h1>
        <p class="hero-role">Adhyaksh, Kisan Mazdur Sangathan</p>
        <p class="hero-summary">
            A .NET-powered public website where farmers, workers, and citizens can submit
            complaints that are delivered to a personal email inbox.
        </p>
        <div class="hero-points">
            <span>Direct complaint submission</span>
            <span>Personal email delivery</span>
            <span>Public-facing profile page</span>
        </div>
        <div class="hero-actions">
            <a class="hero-button primary-button" href="#complaint-form">Open Complaint Box</a>
            <a class="hero-button ghost-button" href="mailto:devpratapsingh211@gmail.com">Direct Mail</a>
        </div>
    </div>

    <div class="hero-card">
        <div class="hero-card-inner">
            <div class="cinematic-orb orb-one"></div>
            <div class="cinematic-orb orb-two"></div>
            <div class="cinematic-grid"></div>
            <p class="hero-card-label">Complaint Delivery</p>
            <h2>Website to Personal Mail</h2>
            <p>
                Every submitted complaint is processed by the .NET backend and sent by SMTP
                to <strong>devpratapsingh211@gmail.com</strong>.
            </p>
            <div class="signal-stack">
                <div class="signal-card">
                    <span class="signal-title">Inbox Route</span>
                    <strong>Secure SMTP</strong>
                </div>
                <div class="signal-card">
                    <span class="signal-title">Complaint Source</span>
                    <strong>Web + Social Media</strong>
                </div>
                <div class="signal-card">
                    <span class="signal-title">Portal Core</span>
                    <strong>ASP.NET 8</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="showcase-strip">
    <article class="showcase-panel accent-panel">
        <p class="eyebrow">Public Reach</p>
        <h3>Built for public complaints from ground level communities</h3>
        <p>
            The portal is designed for farmer, worker, and citizen concerns with a clear direct-to-mail workflow.
        </p>
    </article>
    <article class="showcase-panel dark-panel">
        <p class="eyebrow">Social Intake</p>
        <h3>Track issues received from WhatsApp, Facebook, Instagram, and local meetings</h3>
        <p>
            One interface can be used to organize complaints coming from different public channels.
        </p>
    </article>
</section>

<section class="info-grid">
    <article class="info-card">
        <h3>Who Can Submit</h3>
        <p>Farmers, workers, social groups, and citizens with public or community concerns.</p>
    </article>
    <article class="info-card">
        <h3>Complaint Sources</h3>
        <p>Website complaints can also mention issues received through WhatsApp, Facebook, Instagram, or local meetings.</p>
    </article>
    <article class="info-card">
        <h3>Mail Inbox</h3>
        <p>The receiving inbox is configured for personal mail handling through SMTP settings.</p>
    </article>
</section>

<section class="process-section">
    <div class="panel-heading">
        <p class="eyebrow">How It Works</p>
        <h2>Cinematic, simple, and direct complaint flow</h2>
    </div>
    <div class="process-grid">
        <article class="process-card">
            <span class="process-step">01</span>
            <h3>Citizen submits complaint</h3>
            <p>The public enters name, source, subject, location, and full complaint details in the portal.</p>
        </article>
        <article class="process-card">
            <span class="process-step">02</span>
            <h3>.NET backend processes form</h3>
            <p>The ASP.NET MVC server validates the complaint and prepares the mail body securely.</p>
        </article>
        <article class="process-card">
            <span class="process-step">03</span>
            <h3>Complaint reaches personal inbox</h3>
            <p>The SMTP mail service delivers the complaint directly to the configured email address.</p>
        </article>
    </div>
</section>

<section class="complaint-panel" id="complaint-form">
    <div class="panel-heading">
        <p class="eyebrow">Complaint Box</p>
        <h2>Submit Your Complaint</h2>
        <p>
            Fill in the complaint details below. The portal sends the complaint to the configured personal email account.
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-banner @statusType">@statusMessage</div>
    }

    <form asp-action="Index" asp-controller="Home" method="post" class="complaint-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label>
            Full Name
            <input asp-for="FullName" class="form-input" placeholder="Enter full name" />
            <span asp-validation-for="FullName" class="field-validation"></span>
        </label>

        <label>
            Mobile Number
            <input asp-for="PhoneNumber" class="form-input" placeholder="Enter mobile number" />
            <span asp-validation-for="PhoneNumber" class="field-validation"></span>
        </label>

        <label>
            Village / City
            <input asp-for="Location" class="form-input" placeholder="Enter village or city" />
            <span asp-validation-for="Location" class="field-validation"></span>
        </label>

        <label>
            Complaint Source
            <select asp-for="ComplaintSource" class="form-input">
                <option value="Website">Website</option>
                <option value="WhatsApp">WhatsApp</option>
                <option value="Facebook">Facebook</option>
                <option value="Instagram">Instagram</option>
                <option value="Phone Call">Phone Call</option>
                <option value="Public Meeting">Public Meeting</option>
                <option value="Other">Other</option>
            </select>
            <span asp-validation-for="ComplaintSource" class="field-validation"></span>
        </label>

        <label class="full-width">
            Complaint Subject
            <input asp-for="Subject" class="form-input" placeholder="Enter complaint subject" />
            <span asp-validation-for="Subject" class="field-validation"></span>
        </label>

        <label class="full-width">
            Complaint Details
            <textarea asp-for="Message" class="form-input form-textarea" placeholder="Write complaint details"></textarea>
            <span asp-validation-for="Message" class="field-validation"></span>
        </label>

        <div class="full-width form-actions">
            <button type="submit" class="submit-button">Send Complaint</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
